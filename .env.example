# =============================================
#  ΑΠΑΙΤΟΥΜΕΝΕΣ ΜΕΤΑΒΛΗΤΕΣ
# =============================================

# ---------- Βάση δεδομένων ----------
MYSQL_ROOT_PASSWORD=my_very_strong_root_password
MYSQL_DATABASE=saek_attendance
MYSQL_USER=saek_admin
MYSQL_PASSWORD=my_very_strong_user_password

# ---------- Εφαρμογή ----------
DB_HOST=db
DB_NAME=saek_attendance
DB_USER=saek_admin
DB_PASS=my_very_strong_user_password
TZ=Europe/Athens

# ---------- Διαχειριστής ----------
ADMIN_PASSWORD=admin   # Αλλάξτε μετά την πρώτη σύνδεση

# ---------- Domains ----------
# Domains (αφήστε κενά για τοπική/δοκιμαστική ανάπτυξη)
FRONTEND_DOMAIN=apousies.saek_example.gr
ADMIN_DOMAIN=grammateia.saek_example.gr

# ---------- Εξωτερικό δίκτυο ----------
# Το docker-compose.yml απαιτεί το external_network.
# Για να τρέξετε την εφαρμογή τοπικά (χωρίς Caddy/reverse proxy),
# σχολιάστε τις αντίστοιχες γραμμές στο docker-compose.yml:
#
# 1. Στο service app, σχολιάστε τη γραμμή:
#    - external_network
#
# 2. Στο τέλος του αρχείου, σχολιάστε ολόκληρο το μπλοκ:
#    external_network:
#      external: true
#      name: ${EXTERNAL_NETWORK}
#
# Μετά από αυτό, το compose θα χρησιμοποιήσει μόνο το default network
# και η εφαρμογή θα τρέξει κανονικά στο localhost.
#
# Αν θέλετε να κρατήσετε το external network (π.χ. για παραγωγή),
# αφήστε τα ως έχουν και βεβαιωθείτε ότι το δίκτυο υπάρχει:
#   docker network create saek_example_network
EXTERNAL_NETWORK=saek_example_network